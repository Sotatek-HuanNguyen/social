# Database (Neon PostgreSQL)
# Pooled connection for app queries
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Direct connection for migrations
DIRECT_URL=postgresql://user:password@host/dbname?sslmode=require

# CurrentsAPI (free tier, 600 req/day)
CURRENTS_API_KEY=your_key_here

# Cron secret for Vercel cron job authentication
CRON_SECRET=random_secret_string

# Web Push (VAPID) - generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:your@email.com

# X/Twitter API v2 Bearer Token (free tier: developer.x.com)
X_BEARER_TOKEN=

# Etherscan API key for whale transfer tracking (free: etherscan.io/apis)
ETHERSCAN_API_KEY=
# No key needed: CoinGecko (free v3), DeFiLlama, Binance Futures
